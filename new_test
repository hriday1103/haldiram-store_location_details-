if store_list:
    df = pd.DataFrame(store_list)
    
    
    df.drop_duplicates(subset=["Store Name", "Address"], keep="first", inplace=True)
    
    output_file = "haldirams_delhi_stores.xlsx"
    
    with pd.ExcelWriter(output_file, engine='openpyxl') as writer:
        df.to_excel(writer, index=False, sheet_name="Delhi Stores")
        
       
        worksheet = writer.sheets["Delhi Stores"]
        for col in worksheet.columns:
            max_len = max(len(str(cell.value or '')) for cell in col)
            col_letter = col[0].column_letter
            worksheet.column_dimensions[col_letter].width = max(max_len + 3, 12)

    print(f"\n SUCCESS! All data compiled into '{output_file}' with {len(df)} total stores listed.")
