        if response.status_code == 200:
            soup = BeautifulSoup(response.text, 'html.parser')
            
            
            stores = soup.select('.location-card, .store-info-box, li, div')
            found_on_page = 0
            
            for store in stores:
                text = store.get_text(separator="||", strip=True)
                if "Haldiram" in text and ("New Delhi" in text or "Delhi" in text):
                    parts = [p.strip() for p in text.split("||") if p.strip()]
                    
                    name = next((p for p in parts if "Haldiram's" in p), "Haldiram's Store")
                    phone = next((p for p in parts if p.startswith("+91") or p.replace(" ","").isdigit() and len(p)>8), "N/A")
                    
                    address_parts = []
                    for part in parts:
                        if part != name and part != phone and any(x in part.lower() for x in ["delhi", "road", "plot", "floor", "market", "no"]):
                            address_parts.append(part)
                    address = ", ".join(address_parts) if address_parts else "View on site"
                    
                   
                    store_data = {
                        "Store Name": name,
                        "Address": address,
                        "Phone Number": phone,
                        "City": "Delhi"
                    }
                    
                    if store_data not in store_list:
                        store_list.append(store_data)
                        found_on_page += 1
                        
            print(f" Successfully extracted {found_on_page} unique store entries from page {page}.")
            
        else:
            print(f" Failed to load Page {page}. Status Code: {response.status_code}")
            
    except Exception as e:
        print(f" Error occurred on Page {page}: {e}")
        
